# Database (Neon, Supabase, or any PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/paper_alpha?sslmode=require"

# Clerk Auth - get from https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Finnhub API - get from https://finnhub.io (free tier)
FINNHUB_API_KEY=your_finnhub_api_key

# CoinGecko - used for crypto search only (free, no key required)
COINGECKO_API_KEY=

# LiveCoinWatch - used for all crypto quotes, candles & trending
# Free tier available at https://www.livecoinwatch.com/tools/api
LIVECOINWATCH_API_KEY=your_livecoinwatch_api_key

# Paper trading config
STARTING_BALANCE=100000

# App URL (for webhooks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
