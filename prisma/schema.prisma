generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  username  String   @unique
  email     String   @unique
  avatarUrl String?
  isBot     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account   PaperAccount?
  watchlist WatchlistItem[]
  alerts    PriceAlert[]
}

model PaperAccount {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashBalance     Decimal  @db.Decimal(20, 8)
  startingBalance Decimal  @db.Decimal(20, 8)
  isBot           Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  holdings   Holding[]
  trades     Trade[]
  snapshots  PortfolioSnapshot[]
  stopOrders StopOrder[]
}

model Holding {
  id           String       @id @default(cuid())
  accountId    String
  account      PaperAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol       String
  assetType    AssetType
  quantity     Decimal      @db.Decimal(20, 8)
  avgCostBasis Decimal      @db.Decimal(20, 8)
  realizedPnl  Decimal      @db.Decimal(20, 8) @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([accountId, symbol])
  @@index([accountId])
}

model Trade {
  id         String       @id @default(cuid())
  accountId  String
  account    PaperAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol     String
  assetType  AssetType
  assetName  String
  side       TradeSide
  quantity   Decimal      @db.Decimal(20, 8)
  price      Decimal      @db.Decimal(20, 8)
  totalValue Decimal      @db.Decimal(20, 8)
  note       String?
  reason     String?
  createdAt  DateTime     @default(now())

  @@index([accountId])
  @@index([accountId, symbol])
  @@index([accountId, createdAt])
}

model PortfolioSnapshot {
  id          String       @id @default(cuid())
  accountId   String
  account     PaperAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  totalValue  Decimal      @db.Decimal(20, 8)
  cashBalance Decimal      @db.Decimal(20, 8)
  createdAt   DateTime     @default(now())

  @@index([accountId])
  @@index([accountId, createdAt])
}

model PriceAlert {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol      String
  assetType   AssetType
  targetPrice Decimal        @db.Decimal(20, 8)
  condition   AlertCondition
  triggered   Boolean        @default(false)
  triggeredAt DateTime?
  seenAt      DateTime?
  createdAt   DateTime       @default(now())

  @@index([userId])
  @@index([triggered])
  @@index([symbol])
  @@index([userId, triggered])
}

model WatchlistItem {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  assetType AssetType
  createdAt DateTime  @default(now())

  @@unique([userId, symbol])
  @@index([userId])
  @@index([symbol])
}

enum AssetType {
  STOCK
  CRYPTO
  COMMODITY
}

enum TradeSide {
  BUY
  SELL
  SHORT
  COVER
}

enum AlertCondition {
  ABOVE
  BELOW
}

model StopOrder {
  id           String          @id @default(cuid())
  accountId    String
  account      PaperAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol       String
  assetType    AssetType
  side         TradeSide
  triggerPrice Decimal         @db.Decimal(20, 8)
  condition    AlertCondition
  quantity     Decimal         @db.Decimal(20, 8)
  status       StopOrderStatus @default(ACTIVE)
  triggeredAt  DateTime?
  createdAt    DateTime        @default(now())

  @@index([accountId])
  @@index([status])
}

enum StopOrderStatus {
  ACTIVE
  TRIGGERED
  CANCELLED
  FAILED
}
